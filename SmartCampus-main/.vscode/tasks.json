{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Backend (Maven)",
			"type": "shell",
			"command": "cd smart_campus && mvnw.cmd clean compile",
			"problemMatcher": [
				"$maven"
			]
		},
		{
			"label": "Build Backend",
			"type": "shell",
			"command": "cd smart_campus; & '.\\mvnw.cmd' clean compile; echo 'Build complete'"
		},
		{
			"label": "Run Backend (Spring Boot)",
			"type": "shell",
			"command": "cd smart_campus; & '.\\mvnw.cmd' spring-boot:run",
			"isBackground": true
		}
	]
}